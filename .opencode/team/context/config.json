{
  "version": "0.6.0-p4",
  "maxChunkChars": 2400,
  "chunkOverlapChars": 200,
  "maxStoredTextChars": 5000,
  "defaultSearchLimit": 14,
  "defaultPackMaxChars": 18000,
  "includeKindsInPack": [
    "handoff",
    "evidence",
    "task",
    "research",
    "browser",
    "session",
    "source",
    "note",
    "diagnostic"
  ],
  "noiseLinePatterns": [
    "^\\s*$",
    "^\\s*(downloaded|fetching|installing|resolved|progress|info:)\\b",
    "^\\s*[.]{3,}$",
    "^\\s*\\[[=\\-#> ]+\\]\\s*\\d+%",
    "^\\s*node_modules/",
    "^\\s*packages/.*/node_modules/"
  ],
  "importantLinePatterns": [
    "error",
    "exception",
    "traceback",
    "failed",
    "failure",
    "fail:",
    "panic",
    "fatal",
    "segfault",
    "assert",
    "warning",
    "warn",
    "todo",
    "fixme",
    "blocked",
    "unsupported",
    "needs review",
    "review",
    "audit",
    "passed",
    "success",
    "ok",
    "test",
    "coverage",
    "console",
    "network",
    "404",
    "500",
    "timeout",
    "modified",
    "created",
    "deleted",
    "changed",
    "diff",
    "commit",
    "file:",
    "path:",
    "url:",
    "selector",
    "screenshot"
  ]
}
