    "chrome-bridge:doctor": "node ./scripts/browser-bridge-server.mjs doctor",
    "mcp:browser-bridge": "node ./mcp/browser-bridge-mcp.mjs",
    "research": "node ./scripts/research-runner.mjs",
    "research:doctor": "node ./scripts/research-runner.mjs doctor",
    "mcp:research": "node ./mcp/research-mcp.mjs",
    "context": "node ./scripts/context-runner.mjs",
