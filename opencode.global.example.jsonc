{
  "$schema": "https://opencode.ai/config.json",

  // P8.5 global install example. The installer writes MCP entries into
  // ~/.config/opencode/opencode.jsonc and places agents/commands/plugins under
  // ~/.config/opencode so every project can use them without project install.

  "mcp": {
    "cloakbrowser": {
      "type": "local",
      "command": ["node", "~/.config/opencode/mcp/cloakbrowser-mcp.mjs"],
      "enabled": true,
      "environment": {
        "TEAM_PROJECT_ROOT": ".",
        "CLOAKBROWSER_HEADLESS": "false",
        "CLOAKBROWSER_HUMANIZE": "true",
        "CLOAKBROWSER_PROFILE_DIR": ".opencode/team/browser/profile",
        "CLOAKBROWSER_MANUAL_TIMEOUT_MS": "600000"
      }
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    }
  },

  "lsp": true,
  "permission": {
    "lsp": "allow"
  },

  "agent": {
    "chief-engineer": { "model": "deepseek-custom/deepseek-v4-pro" },
    "minimax-coder": { "model": "minimax/minimax-m2.7" },
    "tester": { "model": "minimax/minimax-m2.7" },
    "browser-actor": { "model": "minimax/minimax-m2.7" },
    "browser-perception": { "model": "deepseek-custom/deepseek-v4-pro" },
    "reviewer": { "model": "deepseek-custom/deepseek-v4-pro" },
    "auditor": { "model": "openai/gpt-5.5" },
    "visual-reviewer": { "model": "openai/gpt-5.5" },
    "handoff-writer": { "model": "qwen-custom/qwen3.7-max" },
    "overnight-supervisor": { "model": "deepseek-custom/deepseek-v4-pro" }
  }
}
