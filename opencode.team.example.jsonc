{
  "$schema": "https://opencode.ai/config.json",

  // Copy relevant sections into your project opencode.json.
  // Replace provider/model ids with your real IDs.

  "plugin": ["./.opencode/plugins/team-runtime.js"],

  "mcp": {
    "cloakbrowser": {
      "type": "local",
      "command": ["node", "./.opencode/mcp/cloakbrowser-mcp.mjs"],
      "enabled": true,
      "environment": {
        "TEAM_PROJECT_ROOT": ".",
        "CLOAKBROWSER_HEADLESS": "false",
        "CLOAKBROWSER_HUMANIZE": "true",
        "CLOAKBROWSER_PROFILE_DIR": ".opencode/team/browser/profile",
        "CLOAKBROWSER_MANUAL_TIMEOUT_MS": "600000"
      }
    },
    "browser-bridge": {
      "type": "local",
      "command": ["node", "./.opencode/mcp/browser-bridge-mcp.mjs"],
      "enabled": true,
      "environment": {
        "TEAM_PROJECT_ROOT": ".",
        "OPENCODE_BROWSER_BRIDGE_PORT": "37987",
        "OPENCODE_BROWSER_BRIDGE_TOKEN": "dev-local"
      }
    },
    "research": {
      "type": "local",
      "command": ["node", "./.opencode/mcp/research-mcp.mjs"],
      "enabled": true,
      "environment": {
        "TEAM_PROJECT_ROOT": "."
      }
    },
    "context": {
      "type": "local",
      "command": ["node", "./.opencode/mcp/context-mcp.mjs"],
      "enabled": true,
      "environment": {
        "TEAM_PROJECT_ROOT": "."
      }
    },
    "router": {
      "type": "local",
      "command": ["node", "./.opencode/mcp/router-mcp.mjs"],
      "enabled": true,
      "environment": {
        "TEAM_PROJECT_ROOT": "."
      }
    },
    "memory": {
      "type": "local",
      "command": ["node", "./.opencode/mcp/memory-mcp.mjs"],
      "enabled": true,
      "environment": {
        "TEAM_PROJECT_ROOT": "."
      }
    },
    "patch": {
      "type": "local",
      "command": ["node", "./.opencode/mcp/patch-mcp.mjs"],
      "enabled": true,
      "environment": {
        "TEAM_PROJECT_ROOT": "."
      }
    },
    "overnight": {
      "type": "local",
      "command": ["node", "./.opencode/mcp/overnight-mcp.mjs"],
      "enabled": true,
      "environment": {
        "TEAM_PROJECT_ROOT": "."
      }
    }
  },

  "provider": {
    "minimax": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MiniMax",
      "options": {
        "baseURL": "{env:MINIMAX_BASE_URL}",
        "apiKey": "{env:MINIMAX_API_KEY}"
      },
      "models": {
        "minimax-m2.7": { "name": "MiniMax M2.7" }
      }
    },
    "deepseek-custom": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek Custom",
      "options": {
        "baseURL": "{env:DEEPSEEK_BASE_URL}",
        "apiKey": "{env:DEEPSEEK_API_KEY}"
      },
      "models": {
        "deepseek-v4-pro": { "name": "DeepSeek V4 Pro" }
      }
    },
    "qwen-custom": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Qwen Custom",
      "options": {
        "baseURL": "{env:QWEN_BASE_URL}",
        "apiKey": "{env:QWEN_API_KEY}"
      },
      "models": {
        "qwen3.7-max": { "name": "Qwen 3.7 Max" }
      }
    }
  },

  "model": "deepseek-custom/deepseek-v4-pro",

  "agent": {
    // Markdown agents live in .opencode/agents/*.md.
    // You can override models per agent here.
    "chief-engineer": {
      "model": "deepseek-custom/deepseek-v4-pro"
    },
    "minimax-coder": {
      "model": "minimax/minimax-m2.7"
    },
    "tester": {
      "model": "minimax/minimax-m2.7"
    },
    "browser-tester": {
      "model": "minimax/minimax-m2.7"
    },
    "browser-perception": {
      "model": "deepseek-custom/deepseek-v4-pro"
    },
    "browser-actor": {
      "model": "minimax/minimax-m2.7"
    },
    "visual-reviewer": {
      "model": "openai/gpt-5.5"
    },
    "context-curator": {
      "model": "deepseek-custom/deepseek-v4-pro"
    },
    "model-router": {
      "model": "deepseek-custom/deepseek-v4-pro"
    },
    "memory-curator": {
      "model": "deepseek-custom/deepseek-v4-pro"
    },
    "improvement-reviewer": {
      "model": "openai/gpt-5.5"
    },
    "log-compressor": {
      "model": "minimax/minimax-m2.7"
    },

    "research-scout": {
      "model": "deepseek-custom/deepseek-v4-pro"
    },
    "research-reviewer": {
      "model": "openai/gpt-5.5"
    },
    "paper-digester": {
      "model": "deepseek-custom/deepseek-v4-pro"
    },
    "code-archaeologist": {
      "model": "deepseek-custom/deepseek-v4-pro"
    },
    "handoff-writer": {
      "model": "qwen-custom/qwen3.7-max"
    },
    "reviewer": {
      "model": "openai/gpt-5.5"
    },
    "auditor": {
      "model": "openai/gpt-5.5"
    }
  }
}
